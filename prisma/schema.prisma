generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum ValidationTaskStatus {
  todo
  in_progress
  done
  blocked
}

enum ShareMode {
  full
  investor
  builder
  accelerator
}

enum Visibility {
  private
  unlisted
  public
}

enum AIJobStatus {
  queued
  running
  succeeded
  failed
}

model User {
  id             String           @id @default(cuid())
  name           String
  email          String           @unique
  passwordHash   String?
  role           UserRole         @default(user)
  founderProfile FounderProfile?
  observations   Observation[]
  scans          BusinessScan[]
  proofChecks    ProofCheck[]
  dossiers       StartupDossier[]
  analytics      AnalyticsEvent[]
  aiJobs         AIJob[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model FounderProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  background         String?
  roleType           String?
  industry           String?
  yearsExperience    Int?
  strengths          Json?
  communicationStyle String?
  riskComfort        String?
  validationComfort  String?
  technicalAbility   String?
  networkAccess      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Observation {
  id           String           @id @default(cuid())
  userId       String?
  user         User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  text         String
  context      String?
  whereNoticed String
  intent       String?
  scans        BusinessScan[]
  dossiers     StartupDossier[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model BusinessScan {
  id                     String          @id @default(cuid())
  userId                 String?
  user                   User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  observationId          String
  observation            Observation     @relation(fields: [observationId], references: [id], onDelete: Cascade)
  summary                String
  signalTypes            Json
  affectedGroups         Json
  currentWorkarounds     Json
  businessPotentialScore Int
  status                 String
  strongSignals          Json
  weakSignals            Json
  missingProof           Json
  recommendedNextStep    String
  angles                 BusinessAngle[]
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
}

model BusinessAngle {
  id                 String           @id @default(cuid())
  scanId             String
  scan               BusinessScan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  name               String
  oneLineDescription String
  whoItHelps         String
  whoMightPay        String
  whyItMightWork     String
  firstVersion       String
  businessType       String
  difficulty         Int
  potential          Int
  risk               Int
  founderFit         Int
  recommendedNextStep String
  proofChecks        ProofCheck[]
  dossiers           StartupDossier[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model ProofCheck {
  id               String          @id @default(cuid())
  userId           String?
  user             User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  businessAngleId  String
  businessAngle    BusinessAngle   @relation(fields: [businessAngleId], references: [id], onDelete: Cascade)
  proofStrength    Int
  buyerClarity     Int
  mvpClarity       Int
  riskAwareness    Int
  sendability      Int
  missingProof     Json
  summary          String
  answers          ProofAnswer[]
  dossiers         StartupDossier[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ProofAnswer {
  id           String     @id @default(cuid())
  proofCheckId String
  proofCheck   ProofCheck @relation(fields: [proofCheckId], references: [id], onDelete: Cascade)
  question     String
  answer       String
  helperText   String
  scoreSignal  String
  createdAt    DateTime   @default(now())
}

model StartupDossier {
  id              String           @id @default(cuid())
  userId          String?
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  observationId   String
  observation     Observation      @relation(fields: [observationId], references: [id], onDelete: Cascade)
  businessAngleId String
  businessAngle   BusinessAngle    @relation(fields: [businessAngleId], references: [id], onDelete: Cascade)
  proofCheckId    String?
  proofCheck      ProofCheck?      @relation(fields: [proofCheckId], references: [id], onDelete: SetNull)
  startupName     String
  oneLiner        String
  status          String
  readinessScore  Int
  founderFitScore Int
  visibility      Visibility       @default(private)
  sections        DossierSection[]
  validationTasks ValidationTask[]
  shareLinks      ShareLink[]
  exports         ExportRecord[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model DossierSection {
  id          String         @id @default(cuid())
  dossierId   String
  dossier     StartupDossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  sectionType String
  title       String
  content     String
  orderIndex  Int
  updatedAt   DateTime       @updatedAt
}

model ValidationTask {
  id           String               @id @default(cuid())
  dossierId    String
  dossier      StartupDossier       @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  title        String
  description  String
  status       ValidationTaskStatus @default(todo)
  evidenceType String?
  evidenceUrl  String?
  notes        String?
  dueDate      DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model ShareLink {
  id        String         @id @default(cuid())
  dossierId String
  dossier   StartupDossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  token     String         @unique
  mode      ShareMode
  isActive  Boolean        @default(true)
  expiresAt DateTime?
  viewCount Int            @default(0)
  views     ShareView[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ShareView {
  id          String    @id @default(cuid())
  shareLinkId String
  shareLink   ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  viewedAt    DateTime  @default(now())
  referrer    String?
  userAgent   String?
  ipHash      String?
}

model ExportRecord {
  id         String         @id @default(cuid())
  dossierId  String
  dossier    StartupDossier @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  exportType String
  createdAt  DateTime       @default(now())
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventName  String
  properties Json
  createdAt  DateTime @default(now())
}

model AdminSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model AIJob {
  id        String      @id @default(cuid())
  userId    String?
  user      User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  jobType   String
  status    AIJobStatus @default(queued)
  input     Json
  output    Json?
  error     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}
